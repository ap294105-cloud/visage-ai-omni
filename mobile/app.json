{
  "expo": {
    "name": "Visage AI",
    "slug": "visage-ai",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "visageai",
    "userInterfaceStyle": "dark",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.adityapandey.visageai",
      "infoPlist": {
        "NSCameraUsageDescription": "Visage AI requires camera access to perform contactless biometric facial analysis.",
        "NSPhotoLibraryUsageDescription": "Visage AI needs access to save your biometric scan reports.",
        "NSPhotoLibraryAddUsageDescription": "Visage AI needs access to save your biometric scan reports."
      }
    },
    "android": {
      "package": "com.adityapandey.visageai",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundColor": "#050510"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.RECORD_AUDIO",
        "android.permission.INTERNET"
      ],
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#050510",
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
